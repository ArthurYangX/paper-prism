# --- prism private config (CRITICAL: never commit a user's vault path) ---
skills/prism/assets/config.json
# keep the template tracked:
!skills/prism/assets/config.example.json

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/

# --- prism scratch / generated artifacts ---
/tmp/
prism_progress.log
prism_errors.log

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp

# draw.io desktop backups
*.drawio.bkp
.$*

# --- showcase: keep lightweight artifacts (notes, slide source, screenshots,
#     MOCs, slide previews); exclude the heavy, regenerable binaries ---
examples/showcase/run-attention/prism-demo-config.json
examples/showcase/run-attention/*.pdf
examples/showcase/run-attention/vault/**/*.pdf
examples/showcase/run-attention/vault/**/*.pptx
examples/showcase/run-attention/vault/**/.cache/
